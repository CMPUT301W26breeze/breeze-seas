<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ticket_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="10dp"
    android:backgroundTint="@android:color/white"
    app:cardCornerRadius="18dp"
    app:cardElevation="10dp"
    app:strokeWidth="1dp"
    app:strokeColor="#0F000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/ticket_status_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="Status icon"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/ticket_event_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Beginner Swimming Lesson"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#111827"
            app:layout_constraintTop_toTopOf="@id/ticket_status_icon"
            app:layout_constraintStart_toEndOf="@id/ticket_status_icon"
            app:layout_constraintEnd_toStartOf="@id/status_container"
            app:layout_constraintHorizontal_bias="0" />

        <TextView
            android:id="@+id/ticket_event_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Aug 15, 2026 • 6:00 PM"
            android:textSize="13sp"
            android:textColor="#6B7280"
            app:layout_constraintTop_toBottomOf="@id/ticket_event_title"
            app:layout_constraintStart_toEndOf="@id/ticket_status_icon"
            app:layout_constraintEnd_toStartOf="@id/status_container" />

        <FrameLayout
            android:id="@+id/status_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/ticket_status_icon"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.chip.Chip
                android:id="@+id/ticket_status_chip"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="Pending"
                android:textSize="12sp"
                android:textColor="#111827"
                app:chipCornerRadius="16dp"
                app:chipMinHeight="32dp"
                app:chipStrokeWidth="1dp"
                app:chipStrokeColor="#1F000000"
                app:chipBackgroundColor="@android:color/white"
                app:ensureMinTouchTargetSize="false"
                app:textEndPadding="10dp"
                app:textStartPadding="10dp" />

            <View
                android:id="@+id/action_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="-2dp"
                android:layout_marginEnd="-2dp"
                android:background="@drawable/red_dot"
                android:visibility="gone" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>